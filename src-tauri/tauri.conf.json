{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "自动滚屏",
  "version": "0.1.0",
  "identifier": "com.yjh.auto-scroll",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "自动滚屏",
        "width": 520,
        "height": 680,
        "resizable": true,
        "minWidth": 420,
        "minHeight": 520,
        "center": true,
        "visible": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
